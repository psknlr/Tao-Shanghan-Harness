{"initial_rule_id": "IR_SHL_0134_002", "clause_id": "SHL_SONGBEN_0134", "six_channel": "太陽病", "rule_type": "formula_pattern_rule", "if_conditions": {"disease": ["太陽病", "結胸"], "symptoms": ["頭痛", "發熱", "微盜汗出", "反惡寒", "短氣", "躁煩", "心中懊憹", "心下因硬"], "negated_findings": [], "pulse": ["浮", "浮數動"], "prior_treatment": ["醫反下之"], "time_course": []}, "then_conclusions": {"formula": ["大陷胸湯"], "treatment_principle": ["下之"], "alternatives": []}, "evidence_span": "太陽病，脈浮而動數，浮則為風，數則為熱，動則為痛，數則為虛。頭痛發熱，微盜汗出，而反惡寒者，表未解也，醫反下之，動數變遲，膈內拒痛，胃中空虛，客氣動膈，短氣躁煩，心中懊憹，陽氣內陷，心下因硬，則為結胸，大陷胸湯主之。若不結胸，但頭汗出，餘處無汗，劑頸而還，小便不利，身必發黃。", "evidence_type": "original_text", "interpretation": "該條可作為大陷胸湯相關方證的原文證據，原文用語為「大陷胸湯主之」，證據強度：主治關係（主之）。", "interpretation_level": "normalized", "model_confidence": 0.9, "prescription_strength": "主之", "autonomous_review": {"evidence_verified": true, "schema_valid": true, "semantic_result": "warn", "critic_result": "pass", "critic_flags": [], "repairs": [], "consensus_score": 0.896, "release_level": "silver"}}
