{"initial_rule_id": "IR_SHL_0149_003", "clause_id": "SHL_SONGBEN_0149", "six_channel": "太陽病", "rule_type": "formula_pattern_rule", "if_conditions": {"disease": ["結胸"], "symptoms": ["發熱", "汗出"], "negated_findings": [], "pulse": [], "prior_treatment": ["下之"], "time_course": []}, "then_conclusions": {"formula": ["大陷胸湯"], "treatment_principle": ["下之"], "alternatives": ["小柴胡湯", "小柴胡湯", "半夏瀉心湯"]}, "evidence_span": "傷寒五六日，嘔而發熱者，柴胡湯證具，而以他藥下之，柴胡證仍在者，復與柴胡湯。此雖已下之，不為逆，必蒸蒸而振，卻發熱汗出而解。若心下滿而硬痛者，此為結胸也，大陷胸湯主之。但滿而不痛者，此為痞，柴胡不中與之，宜半夏瀉心湯。", "evidence_type": "original_text", "interpretation": "該條可作為大陷胸湯相關方證的原文證據，原文用語為「大陷胸湯主之」，證據強度：主治關係（主之）。", "interpretation_level": "normalized", "model_confidence": 0.9, "prescription_strength": "主之", "autonomous_review": {"evidence_verified": true, "schema_valid": true, "semantic_result": "pass", "critic_result": "pass", "critic_flags": [], "repairs": [], "consensus_score": 0.956, "release_level": "gold"}}
